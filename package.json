{
  "name": "siteshot-auditor-studio-ultra",
  "version": "3.2.23",
  "private": true,
  "type": "module",
  "description": "SiteShot Auditor Studio Ultra v3.2.23 final verification: rechecked Auto/Sitemap, fixed Last Run newest-run selection, and made sidebar Last Run card actionable.",
  "main": "desktop/main.mjs",
  "bin": {
    "siteshot": "./bin/siteshot.mjs"
  },
  "scripts": {
    "start": "electron .",
    "desktop": "electron .",
    "audit": "node bin/siteshot.mjs audit",
    "audit:eventflow": "node bin/siteshot.mjs audit --config examples/eventflow.ultra-audit.json",
    "audit:eventflow:public": "node bin/siteshot.mjs audit --config examples/eventflow-public.ultra-audit.json",
    "audit:eventflow:full": "node bin/siteshot.mjs audit --config examples/eventflow-full.ultra-audit.json",
    "doctor": "node bin/siteshot.mjs doctor",
    "init": "node bin/siteshot.mjs init",
    "compare": "node bin/siteshot.mjs compare",
    "zip": "node bin/siteshot.mjs zip",
    "install:browsers": "npx playwright install chromium",
    "install:browsers:with-deps": "npx playwright install --with-deps chromium",
    "install:browsers:bundled": "cross-env PLAYWRIGHT_BROWSERS_PATH=playwright-browsers npx playwright install chromium",
    "dist:win": "electron-builder --win --x64 --dir",
    "pack:win": "electron-builder --win --x64 --dir",
    "dist:installer": "npm run install:browsers:bundled && electron-builder --win nsis --x64",
    "installer:win": "npm run dist:installer",
    "check": "node --check bin/siteshot.mjs && node --check src/audit.mjs && node --check src/lib/config.mjs && node --check src/lib/devices.mjs && node --check src/lib/playwright-runtime.mjs && node --check desktop/main.mjs && node --check src/reporting/reports.mjs && node --check scripts/preflight-check.mjs && node --check scripts/premerge-check.mjs && node --check scripts/config-smoke-check.mjs && node --check scripts/installer-smoke-check.mjs",
    "check:repo": "node scripts/premerge-check.mjs",
    "check:config": "node scripts/config-smoke-check.mjs",
    "check:installer": "node scripts/installer-smoke-check.mjs",
    "preflight": "node scripts/preflight-check.mjs",
    "verify": "npm run check && npm run check:repo && npm run check:config && npm run check:installer && npm run preflight"
  },
  "dependencies": {
    "playwright": "^1.49.1",
    "axe-core": "^4.10.2",
    "docx": "^9.5.1"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "electron-builder": "^25.1.8",
    "electron": "^34.0.0"
  },
  "engines": {
    "node": ">=18"
  },
  "build": {
    "appId": "uk.siteshot.auditorstudio",
    "productName": "SiteShot Auditor Studio",
    "artifactName": "install.${ext}",
    "directories": {
      "output": "release"
    },
    "files": [
      "desktop/**/*",
      "src/**/*",
      "bin/**/*",
      "examples/**/*",
      "templates/**/*",
      "assets/**/*",
      "docs/**/*",
      "scripts/**/*",
      "package.json",
      "README.md",
      "README FIRST - WINDOWS.txt"
    ],
    "extraResources": [
      {
        "from": "playwright-browsers",
        "to": "playwright-browsers"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "publisherName": "SiteShot",
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true,
      "shortcutName": "SiteShot Auditor Studio",
      "uninstallDisplayName": "SiteShot Auditor Studio Ultra",
      "runAfterFinish": true,
      "deleteAppDataOnUninstall": false,
      "menuCategory": "SiteShot"
    },
    "asar": false
  },
  "author": "Rhys Lewis"
}
